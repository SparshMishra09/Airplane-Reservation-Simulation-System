generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  name      String
  role      Role      @default(PASSENGER)
  bookings  Booking[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum Role {
  PASSENGER
  ADMIN
}

model Aircraft {
  id        String   @id @default(uuid())
  model     String
  capacity  Int
  flights   Flight[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Flight {
  id            String       @id @default(uuid())
  flightNumber  String       @unique
  origin        String
  destination   String
  departureTime DateTime
  arrivalTime   DateTime
  aircraftId    String
  aircraft      Aircraft     @relation(fields: [aircraftId], references: [id])
  basePrice     Float
  status        FlightStatus @default(SCHEDULED)
  airline       String?
  recurrence    String?      // "NONE" | "DAILY" | "WEEKLY" | "MONTHLY"
  isTemplate    Boolean      @default(false)
  seats         Seat[]
  bookings      Booking[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([origin, destination])
  @@index([isTemplate, recurrence])
}

enum FlightStatus {
  SCHEDULED
  DELAYED
  CANCELLED
  COMPLETED
}

model Seat {
  id          String    @id @default(uuid())
  flightId    String
  flight      Flight    @relation(fields: [flightId], references: [id])
  seatNumber  String
  seatClass   SeatClass @default(ECONOMY)
  isAvailable Boolean   @default(true)
  price       Float
  bookingId   String?
  booking     Booking?  @relation(fields: [bookingId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([flightId, seatNumber])
}

enum SeatClass {
  ECONOMY
  BUSINESS
  FIRST_CLASS
}

model Booking {
  id                        String        @id @default(uuid())
  pnr                       String        @unique @db.VarChar(6)
  userId                    String
  user                      User          @relation(fields: [userId], references: [id])
  flightId                  String
  flight                    Flight        @relation(fields: [flightId], references: [id])
  status                    BookingStatus @default(PENDING)
  totalAmount               Float
  passengerName             String?
  passengerEmail            String?
  documentId                String?
  meal                      String?
  checkedBags               Int           @default(0)
  hasCancellationProtection Boolean       @default(false)
  seats                     Seat[]
  createdAt                 DateTime      @default(now())
  updatedAt                 DateTime      @updatedAt

  @@index([pnr])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REFUNDED
}

// ── Audit Log (immutable trail) ──────────────────────────
model AuditLog {
  id          String   @id @default(uuid())
  action      String   // e.g. "FLIGHT_PRICE_CHANGED", "BOOKING_CANCELLED", "REFUND_ISSUED"
  entityType  String   // "Flight", "Booking", "MealItem", "BaggagePolicy"
  entityId    String
  performedBy String   // Admin user ID
  adminName   String?  // Admin display name for quick rendering
  details     String   // JSON string with before/after data
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([performedBy])
  @@index([createdAt])
}

// ── Meal & Service Catalog ───────────────────────────────
model MealCategory {
  id        String     @id @default(uuid())
  name      String     @unique // "Standard", "Premium", "Special"
  items     MealItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model MealItem {
  id         String       @id @default(uuid())
  name       String       // "Vegetarian", "Vegan", "Halal", etc.
  price      Float
  categoryId String
  category   MealCategory @relation(fields: [categoryId], references: [id])
  isActive   Boolean      @default(true)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

// ── Baggage Policy Manager ───────────────────────────────
model BaggagePolicy {
  id             String   @id @default(uuid())
  name           String   @unique // "Domestic Economy", "International Business", etc.
  freeWeightKg   Float    // Free baggage allowance in kg
  maxWeightKg    Float    // Maximum allowed weight
  extraCostPerKg Float    // Cost per extra kg beyond free allowance
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
